{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AWord",
  "version": "0.1.0",
  "identifier": "vn.aword.lite",
  "build": {
    "frontendDist": "../../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AWord",
        "width": 1200,
        "height": 820,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "backgroundColor": "#1e1e1e",
        "additionalBrowserArgs": "--disable-http-cache --disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection"
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"]
  }
}
