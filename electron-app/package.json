{
  "private": true,
  "name": "electron-app",
  "version": "20260716.23.35",
  "main": "lib/backend/electron-main.js",
  "dependencies": {
    "@theia/core": "1.73.1",
    "@theia/editor": "1.73.1",
    "@theia/electron": "1.73.1",
    "@theia/filesystem": "1.73.1",
    "@theia/markers": "1.73.1",
    "@theia/messages": "1.73.1",
    "@theia/monaco": "1.73.1",
    "@theia/navigator": "1.73.1",
    "@theia/plugin-ext": "1.73.1",
    "@theia/plugin-ext-vscode": "1.73.1",
    "@theia/preferences": "1.73.1",
    "@theia/process": "1.73.1",
    "@theia/search-in-workspace": "1.73.1",
    "@theia/terminal": "1.73.1",
    "@theia/workspace": "1.73.1",
    "@vscode/windows-ca-certs": "^0.3.4",
    "aword-chat": "0.0.0"
  },
  "devDependencies": {
    "@theia/cli": "1.73.1",
    "electron": "39.8.7",
    "electron-builder": "^24.13.3"
  },
  "scripts": {
    "bundle": "npm run rebuild && theia build --mode production",
    "rebuild": "theia rebuild:electron --cacheRoot ..",
    "start": "theia start --plugins=local-dir:plugins",
    "watch": "npm run rebuild && theia build --watch --mode development",
    "prepackage": "node scripts/prepackage.cjs",
    "package": "electron-builder --win --x64 --publish never"
  },
  "theia": {
    "target": "electron",
    "frontend": {
      "config": {
        "applicationName": "AWord",
        "defaultLocale": "vi",
        "electron": {
          "splashScreenOptions": {
            "content": "resources/splash/index.html",
            "width": 480,
            "height": 320
          }
        },
        "preferences": {
          "workbench.colorTheme": "dark",
          "window.titleBarStyle": "custom",
          "window.menuBarVisibility": "classic",
          "workbench.statusBar.visible": false,
          "workbench.tree.renderIndentGuides": "onHover",
          "claudeCode.preferredLocation": "sidebar",
          "claudeCode.hideOnboarding": true,
          "claudeCode.initialPermissionMode": "acceptEdits",
          "files.autoSave": "off",
          "workbench.editorAssociations": {
            "*.md": "default"
          },
          "files.watcherExclude": {
            "**/.git/objects/**": true,
            "**/.git/subtree-cache/**": true,
            "**/node_modules/**": true,
            "**/.venv/**": true,
            "**/__pycache__/**": true,
            "**/dist/**": true,
            "**/out/**": true,
            "**/.cache/**": true,
            "**/AppData/**": true
          },
          "search.exclude": {
            "**/node_modules": true,
            "**/.venv": true,
            "**/__pycache__": true,
            "**/dist": true,
            "**/out": true,
            "**/.git": true
          }
        }
      }
    }
  },
  "theiaPluginsDir": "plugins",
  "theiaPlugins": {
    "Anthropic.claude-code": "https://open-vsx.org/api/Anthropic/claude-code/win32-x64/2.1.211/file/Anthropic.claude-code-2.1.211@win32-x64.vsix",
    "tomoki1207.pdf": "https://open-vsx.org/api/tomoki1207/pdf/1.2.2/file/tomoki1207.pdf-1.2.2.vsix",
    "cweijan.vscode-office": "https://open-vsx.org/api/cweijan/vscode-office/4.1.5/file/cweijan.vscode-office-4.1.5.vsix",
    "yzhang.markdown-all-in-one": "https://open-vsx.org/api/yzhang/markdown-all-in-one/3.6.2/file/yzhang.markdown-all-in-one-3.6.2.vsix"
  },
  "build": {
    "appId": "vn.aword.app",
    "productName": "AWord",
    "copyright": "AWord",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "asar": true,
    "asarUnpack": [
      "**/lib/backend/native/**",
      "**/lib/backend/shell-integrations/**",
      "**/lib/prebuilds/**",
      "**/*.node"
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "lib",
      "node_modules",
      "resources/splash/**",
      "!**/*.js.map",
      "!**/*.css.map"
    ],
    "extraResources": [
      { "from": "plugins", "to": "app/plugins" },
      { "from": "resources/skills", "to": "app/resources/skills" },
      { "from": "resources/pytools", "to": "pytools" }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "AWord-Setup-${version}.${ext}",
      "include": "installer.nsh",
      "shortcutName": "AWord",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
