{
  "language": "vietnamese",
  "env": {
    "ANTHROPIC_BASE_URL": "https://cortex-memory.com/",
    "ANTHROPIC_AUTH_TOKEN": "xxxx",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "aws/claude-opus-4-8-high",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "aws/claude-sonnet-4-6-high",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "aws/claude-haiku-4-5",
    "ANTHROPIC_SMALL_FAST_MODEL": "aws/claude-haiku-4-5",

    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "MAX_THINKING_TOKENS": "8000",

    "PYTHONIOENCODING": "utf-8",
    "PYTHONUTF8": "1",
    "LANG": "en_US.UTF-8",
    "LC_ALL": "en_US.UTF-8",
    "CHCP": "65001"
  },
  "permissions": {
    "allow": [
      "Bash(*)"
    ],
    "additionalDirectories": []
  },
  "autoUpdatesChannel": "latest",
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
